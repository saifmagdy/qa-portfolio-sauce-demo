{
  "info": {
    "name": "SauceDemo API Collection",
    "description": "API test collection for Sauce Demo e-commerce application.\nAuthor: Saif Magdy | QA Automation Engineer\nUpwork: https://www.upwork.com/freelancers/~01b4c7eaf17658e2cc",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://www.saucedemo.com",
      "type": "string"
    },
    {
      "key": "valid_username",
      "value": "standard_user",
      "type": "string"
    },
    {
      "key": "valid_password",
      "value": "secret_sauce",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST Login - Valid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Redirected to inventory', function() { pm.expect(pm.response.url).to.include('inventory'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "user-name",
                  "value": "{{valid_username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{valid_password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}",
              "host": [
                "{{base_url}}"
              ]
            }
          }
        },
        {
          "name": "POST Login - Invalid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login rejected with error', function() { pm.expect(pm.response.text()).to.include('Username and password do not match'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "user-name",
                  "value": "wrong_user",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "wrong_pass",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}",
              "host": [
                "{{base_url}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Product Catalog",
      "item": [
        {
          "name": "GET Inventory Page",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Page contains products', function() { pm.expect(pm.response.text()).to.include('inventory_item'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/inventory.html",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "inventory.html"
              ]
            }
          }
        },
        {
          "name": "GET Product Detail Page",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Product detail displayed', function() { pm.expect(pm.response.text()).to.include('inventory_details'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/inventory-item.html?id=4",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "inventory-item.html"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "4"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "GET Cart Page",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Cart page loaded', function() { pm.expect(pm.response.text()).to.include('cart_contents'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/cart.html",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "cart.html"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "GET Checkout Step 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/checkout-step-one.html",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "checkout-step-one.html"
              ]
            }
          }
        },
        {
          "name": "GET Checkout Step 2",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Order summary present', function() { pm.expect(pm.response.text()).to.include('summary_info'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/checkout-step-two.html",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "checkout-step-two.html"
              ]
            }
          }
        },
        {
          "name": "GET Order Confirmation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() { pm.response.to.have.status(200); });",
                  "pm.test('Confirmation page loaded', function() { pm.expect(pm.response.text()).to.include('checkout_complete'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/checkout-complete.html",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "checkout-complete.html"
              ]
            }
          }
        }
      ]
    }
  ]
}
